# ─── Steward Admin — Production Environment Variables ────────────────────────────────────
#
# These variables are embedded at build time by Next.js.
#

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Backend WebSocket URL
NEXT_PUBLIC_WS_URL=http://localhost:4000

# Menu frontend URL (used for generating restaurant menu links and QR codes)
NEXT_PUBLIC_MENU_URL=https://steward-menu.pages.dev
