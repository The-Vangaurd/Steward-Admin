# ─── Steward Admin — Environment Variables ────────────────────────────────────
#
# Copy this file to .env.local for local development.
# In production (Vercel), set these as Environment Variables in the dashboard.
#
# CRITICAL: NEXT_PUBLIC_API_URL is embedded at BUILD TIME by Next.js.
# If it is missing or wrong at build time, all API calls fail in production.
# Set it in Vercel: Settings → Environment Variables → NEXT_PUBLIC_API_URL

# Backend API base URL (include /v1 path prefix)
# Local:      http://localhost:4000/v1
# Production: https://your-backend.onrender.com/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Backend WebSocket URL (no /v1 prefix)
# Local:      http://localhost:4000
# Production: https://your-backend.onrender.com
NEXT_PUBLIC_WS_URL=http://localhost:4000
